# Groq API key — free at https://console.groq.com (starts with "gsk_")
GROQ_API_KEY=your_groq_api_key_here

# Telegram bot token — create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Qdrant Cloud — free 1 GB cluster at https://cloud.qdrant.io
QDRANT_URL=https://your-cluster-id.region.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Public HTTPS URL of your deployed app (set this AFTER your first Render deploy)
WEBHOOK_URL=https://your-app-name.onrender.com

# Optional — defaults shown
COLLECTION_NAME=ml_book
MEMORY_WINDOW=10
PDF_PATH=PDFs/your-book.pdf
